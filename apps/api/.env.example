APP_NAME=Personal AI Agent Workspace API
APP_ENV=development
API_VERSION=0.1.0
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Cloud Run uses CORS_ORIGINS. The app accepts both names for compatibility.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_ai_agent_workspace
JWT_SECRET_KEY=change-me-in-development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PROVIDER_API_KEY_ENCRYPTION_KEY=
