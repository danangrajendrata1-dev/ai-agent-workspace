APP_NAME=Personal AI Agent Workspace API
APP_ENV=development
API_VERSION=0.1.0
# JSON array. No trailing slash. Use only approved frontend origins.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_ai_agent_workspace
JWT_SECRET_KEY=change-me-in-development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Fernet key for encrypted provider API key storage.
PROVIDER_API_KEY_ENCRYPTION_KEY=
